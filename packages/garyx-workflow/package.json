{
  "name": "@garyx/workflow",
  "version": "0.0.0",
  "type": "module",
  "description": "TypeScript SDK for Garyx observable workflows.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "examples",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "development-loop:example": "bun examples/development-loop/workflow.ts",
    "deep-research:example": "bun examples/deep-research/workflow.ts",
    "smoke:real": "node scripts/real-smoke.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  }
}
