{
  "projectId": "0693144a-4d5d-450a-a919-03f4f677ee80",
  "shape": "package",
  "pkg": "garyx-desktop",
  "globalName": "GaryxUI",
  "entry": "./.design-sync/entry.tsx",
  "tsconfig": "tsconfig.json",
  "cssEntry": ".design-sync/compiled.css",
  "buildCmd": ".ds-sync/node_modules/.bin/tailwindcss -i src/renderer/src/styles.css -o .design-sync/compiled.css",
  "readmeHeader": ".design-sync/conventions.md",
  "runtimeFontPrefixes": ["SF Pro", "SF Mono", "IBM Plex", "Segoe UI", "Menlo"],
  "overrides": {
    "Dialog": { "cardMode": "single", "viewport": "560x400" },
    "DropdownMenu": { "cardMode": "single", "viewport": "340x380" },
    "Popover": { "cardMode": "single", "viewport": "340x340" },
    "FloatingActionMenuContent": { "cardMode": "single", "viewport": "320x300" },
    "Table": { "cardMode": "column" }
  },
  "componentSrcMap": {
    "Avatar": "src/renderer/src/components/ui/avatar.tsx",
    "Badge": "src/renderer/src/components/ui/badge.tsx",
    "Button": "src/renderer/src/components/ui/button.tsx",
    "Checkbox": "src/renderer/src/components/ui/checkbox.tsx",
    "Dialog": "src/renderer/src/components/ui/dialog.tsx",
    "DropdownMenu": "src/renderer/src/components/ui/dropdown-menu.tsx",
    "Field": "src/renderer/src/components/ui/field.tsx",
    "FloatingActionMenuContent": "src/renderer/src/components/ui/floating-action-menu.tsx",
    "Input": "src/renderer/src/components/ui/input.tsx",
    "Label": "src/renderer/src/components/ui/label.tsx",
    "Popover": "src/renderer/src/components/ui/popover.tsx",
    "Select": "src/renderer/src/components/ui/select.tsx",
    "Separator": "src/renderer/src/components/ui/separator.tsx",
    "Switch": "src/renderer/src/components/ui/switch.tsx",
    "Table": "src/renderer/src/components/ui/table.tsx",
    "Textarea": "src/renderer/src/components/ui/textarea.tsx",
    "Toggle": "src/renderer/src/components/ui/toggle.tsx",
    "ToggleGroup": "src/renderer/src/components/ui/toggle-group.tsx",
    "ProviderAgentIcon": "src/renderer/src/app-shell/components/ProviderAgentIcon.tsx",
    "AgentOptionAvatar": "src/renderer/src/app-shell/components/AgentOptionAvatar.tsx",
    "RateLimitBanner": "src/renderer/src/app-shell/components/RateLimitBanner.tsx",
    "UpdatePill": "src/renderer/src/app-shell/components/UpdatePill.tsx",
    "ThreadLogPanel": "src/renderer/src/app-shell/components/ThreadLogPanel.tsx"
  }
}
