{
  "name": "garyx-desktop",
  "private": true,
  "version": "0.1.11",
  "description": "Garyx macOS app powered by the Garyx API channel",
  "author": "Garyx",
  "license": "MIT",
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:web": "vite --config vite.web.config.ts",
    "storybook": "vite --config vite.storybook.config.ts --open /storybook.html",
    "storybook:build": "vite build --config vite.storybook.config.ts",
    "build": "npm run build:ui",
    "build:ui": "tsc --noEmit && electron-vite build",
    "build:web": "tsc --noEmit && vite build --config vite.web.config.ts",
    "build:rust": "bash ../../scripts/build-local-cli.sh",
    "build:packaged": "npm run build:ui",
    "preview": "electron-vite preview",
    "install:app": "node ./scripts/install-mac-app.mjs",
    "layout:oracle": "node ./scripts/capture-horizontal-layout-oracle.mjs",
    "transcript-render:oracle": "node ./scripts/transcript-render-oracle.mjs",
    "dist:mac": "npm run build:packaged && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac --config.mac.identity=null --publish never && npm run install:app",
    "dist:dir": "npm run build:packaged && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac --dir --config.mac.identity=null --publish never && npm run install:app",
    "dist:mac:release": "node ./scripts/build-mac-release.mjs",
    "test:unit": "node ./scripts/run-unit-tests.mjs",
    "test:tail-thinking-cdp": "node ./scripts/tail-thinking-cdp-repro.mjs --expect fixed",
    "test:smoke": "npm run dist:dir && node ./scripts/electron-smoke.mjs",
    "test:i18n-literals": "node ./scripts/check-i18n-literals.mjs",
    "verify:mac:release": "node ./scripts/verify-mac-release.mjs",
    "test:stream-pool": "NODE_OPTIONS=--experimental-strip-types electron scripts/stream-pool-smoke.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@lobehub/icons": "^5.6.0",
    "@shadcn/react": "^0.2.0",
    "@streamdown/cjk": "^1.0.3",
    "@streamdown/code": "^1.1.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.3",
    "lucide-react": "^0.577.0",
    "mermaid": "^11.13.0",
    "node-pty": "^1.1.0",
    "prismjs": "^1.30.0",
    "qrcode": "^1.5.4",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@electron/notarize": "^2.5.0",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^22.13.10",
    "@types/prismjs": "^1.26.6",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.5",
    "@vitejs/plugin-react": "^5.1.4",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "playwright": "^1.58.2",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.8.2",
    "vite": "^7.3.1",
    "ws": "^8.19.0"
  },
  "build": {
    "appId": "com.garyx.desktop",
    "productName": "Garyx",
    "artifactName": "Garyx-${version}-${arch}.${ext}",
    "afterPack": "scripts/after-pack-app-update.cjs",
    "afterSign": "scripts/notarize.mjs",
    "icon": "resources/garyx.icns",
    "directories": {
      "output": "dist-release"
    },
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      {
        "from": "resources/trayIcon.png",
        "to": "trayIcon.png"
      },
      {
        "from": "resources/trayIcon@2x.png",
        "to": "trayIcon@2x.png"
      }
    ],
    "mac": {
      "icon": "resources/garyx.icns",
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": true,
      "gatekeeperAssess": true,
      "entitlements": "resources/entitlements.mac.plist",
      "entitlementsInherit": "resources/entitlements.mac.plist",
      "singleArchFiles": "**/node_modules/node-pty/prebuilds/darwin-*/*",
      "x64ArchFiles": "**/node_modules/node-pty/prebuilds/darwin-*/*",
      "protocols": [
        {
          "name": "Garyx Deep Link",
          "schemes": [
            "garyx"
          ]
        }
      ],
      "target": [
        "dmg",
        "zip"
      ]
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Pyiner",
        "repo": "garyx"
      }
    ]
  }
}
