{
  "cases": [
    {
      "name": "no signals means fully idle",
      "input": {
        "messages": [{ "role": "user" }, { "role": "assistant" }],
        "runtimeBusy": false,
        "pendingAckIntentCount": 0,
        "remoteAwaitingAckInputCount": 0,
        "pendingHistoryIntent": false
      },
      "expect": {
        "runActive": false,
        "showPendingAckLoading": false,
        "canSteerQueuedPrompt": false
      }
    },
    {
      "name": "connecting stream alone does not drive activity",
      "input": {
        "messages": [{ "role": "user" }],
        "runtimeBusy": false,
        "pendingAckIntentCount": 0,
        "remoteAwaitingAckInputCount": 0,
        "pendingHistoryIntent": false
      },
      "expect": {
        "runActive": false,
        "showPendingAckLoading": false,
        "canSteerQueuedPrompt": false
      }
    },
    {
      "name": "reconciling stream alone does not drive activity",
      "input": {
        "messages": [{ "role": "user" }, { "role": "assistant" }],
        "runtimeBusy": false,
        "pendingAckIntentCount": 0,
        "remoteAwaitingAckInputCount": 0,
        "pendingHistoryIntent": false
      },
      "expect": {
        "runActive": false,
        "showPendingAckLoading": false,
        "canSteerQueuedPrompt": false
      }
    },
    {
      "name": "disconnected stream alone is not an active run",
      "input": {
        "messages": [{ "role": "user" }],
        "runtimeBusy": false,
        "pendingAckIntentCount": 0,
        "remoteAwaitingAckInputCount": 0,
        "pendingHistoryIntent": false
      },
      "expect": {
        "runActive": false,
        "showPendingAckLoading": false,
        "canSteerQueuedPrompt": false
      }
    },
    {
      "name": "busy runtime counts as an active run",
      "input": {
        "messages": [{ "role": "user" }],
        "runtimeBusy": true,
        "pendingAckIntentCount": 0,
        "remoteAwaitingAckInputCount": 0,
        "pendingHistoryIntent": false
      },
      "expect": {
        "runActive": true,
        "showPendingAckLoading": false,
        "canSteerQueuedPrompt": true
      }
    },
    {
      "name": "server-tracked active run alone does not drive rendering gates",
      "input": {
        "messages": [{ "role": "user" }],
        "runtimeBusy": false,
        "pendingAckIntentCount": 0,
        "remoteAwaitingAckInputCount": 0,
        "pendingHistoryIntent": false
      },
      "expect": {
        "runActive": false,
        "showPendingAckLoading": false,
        "canSteerQueuedPrompt": false
      }
    },
    {
      "name": "runtime busy remains a business gate while assistant text is visible",
      "input": {
        "messages": [{ "role": "user" }, { "role": "assistant" }],
        "runtimeBusy": true,
        "pendingAckIntentCount": 0,
        "remoteAwaitingAckInputCount": 0,
        "pendingHistoryIntent": false
      },
      "expect": {
        "runActive": true,
        "showPendingAckLoading": false,
        "canSteerQueuedPrompt": true
      }
    },
    {
      "name": "pending ack intents keep local loading visible",
      "input": {
        "messages": [{ "role": "user" }],
        "runtimeBusy": true,
        "pendingAckIntentCount": 1,
        "remoteAwaitingAckInputCount": 0,
        "pendingHistoryIntent": false
      },
      "expect": {
        "runActive": true,
        "showPendingAckLoading": true,
        "canSteerQueuedPrompt": true
      }
    },
    {
      "name": "remote awaiting-ack inputs show pending ack loading even when idle",
      "input": {
        "messages": [{ "role": "user" }],
        "runtimeBusy": false,
        "pendingAckIntentCount": 0,
        "remoteAwaitingAckInputCount": 2,
        "pendingHistoryIntent": false
      },
      "expect": {
        "runActive": false,
        "showPendingAckLoading": true,
        "canSteerQueuedPrompt": true
      }
    },
    {
      "name": "history-pending intent shows ack loading while the user awaits a reply",
      "input": {
        "messages": [{ "role": "assistant" }, { "role": "user" }],
        "runtimeBusy": false,
        "pendingAckIntentCount": 0,
        "remoteAwaitingAckInputCount": 0,
        "pendingHistoryIntent": true
      },
      "expect": {
        "runActive": false,
        "showPendingAckLoading": true,
        "canSteerQueuedPrompt": true
      }
    },
    {
      "name": "history-pending intent stays quiet once assistant progress lands",
      "input": {
        "messages": [{ "role": "user" }, { "role": "tool_use" }],
        "runtimeBusy": false,
        "pendingAckIntentCount": 0,
        "remoteAwaitingAckInputCount": 0,
        "pendingHistoryIntent": true
      },
      "expect": {
        "runActive": false,
        "showPendingAckLoading": false,
        "canSteerQueuedPrompt": false
      }
    },
    {
      "name": "loop continuation user turns do not count as awaiting a reply",
      "input": {
        "messages": [
          { "role": "user" },
          { "role": "assistant" },
          { "role": "user", "internal": true, "internalKind": "loop_continuation" }
        ],
        "runtimeBusy": false,
        "pendingAckIntentCount": 0,
        "remoteAwaitingAckInputCount": 0,
        "pendingHistoryIntent": true
      },
      "expect": {
        "runActive": false,
        "showPendingAckLoading": false,
        "canSteerQueuedPrompt": false
      }
    }
  ]
}
